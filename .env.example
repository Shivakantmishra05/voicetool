ENVIRONMENT=local
PUBLIC_BASE_URL=https://your-ngrok-domain.ngrok-free.app
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

DATABASE_URL=postgresql+asyncpg://dreamhome:dreamhome@postgres:5432/dreamhome
REDIS_URL=redis://redis:6379/0
REQUIRE_REDIS=false

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-real-token
TWILIO_PHONE_NUMBER=+15551234567
STREAM_TOKEN_SECRET=replace-with-random-32-byte-secret
STREAM_TOKEN_TTL_SECONDS=120

OPENAI_API_KEY=replace-with-real-openai-key
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=shimmer
OPENAI_REALTIME_SPEED=1.0
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=replace-with-supabase-key

DEEPGRAM_API_KEY=replace-with-real-key
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en-IN
DEEPGRAM_ENDPOINTING_MS=500
DEEPGRAM_UTTERANCE_END_MS=1500

GEMINI_API_KEY=replace-with-real-key
GEMINI_MODEL=gemini-2.5-flash-lite
LLM_TIMEOUT_SECONDS=4

ELEVENLABS_API_KEY=replace-with-real-key
ELEVENLABS_VOICE_ID=replace-with-real-voice-id
ELEVENLABS_FALLBACK_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=pcm_16000
TTS_TIMEOUT_SECONDS=8

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_SESSION_SECRET=replace-with-random-32-byte-secret

STARTUP_PROVIDER_CHECKS_ENABLED=true
STARTUP_PROVIDER_CHECKS_REQUIRED=false
PROVIDER_CHECK_TIMEOUT_SECONDS=5

MAX_MEMORY_TURNS=40
MAX_TRANSCRIPT_CHARS=32000
OUTBOUND_AUDIO_QUEUE_SIZE=64
TRANSCRIPT_QUEUE_SIZE=12
LLM_SENTENCE_QUEUE_SIZE=8
MIN_TTS_FRAGMENT_CHARS=18
MAX_TTS_FRAGMENT_CHARS=80
DEEPGRAM_KEEPALIVE_SECONDS=5
DEEPGRAM_RECONNECT_ATTEMPTS=2
